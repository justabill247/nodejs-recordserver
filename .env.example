# === Server Configuration ===
PORT=4000
ALLOWED_ORIGIN=*
LOG_LEVEL=info
FFMPEG_LOG_MODE=basic

# === Directory Configuration (use absolute paths in production/containers) ===
# Recordings directory - where audio files are stored
# Default: <project-root>/recordings
# For LXC: /recordings (bind mount from host)
RECORDINGS_DIR=./recordings

# Logs directory - where application logs are written
# Default: <project-root>/logs
# For LXC: /var/log/recordServer
LOGS_DIR=./logs

# Database path - SQLite database file location
# Default: <project-cwd>/serverDb.db
# For LXC: /var/lib/recordServer/serverDb.db
DB_PATH=./serverDb.db

# Logos directory - where stream logos are stored
# Default: <project-root>/logos
# For LXC: /var/lib/recordServer/logos
LOGOS_DIR=./logos

# Frontend directory - where built Vue app is served from (port 4000)
# Default: <project-root>/public
# For LXC: /var/lib/recordServer/public
FRONTEND_DIR=./public

# === LXC/Container Deployment Example ===
# For a Proxmox LXC container with Tailscale, use:
#
# RECORDINGS_DIR=/recordings
# LOGS_DIR=/var/log/recordServer
# DB_PATH=/var/lib/recordServer/serverDb.db
# LOGOS_DIR=/var/lib/recordServer/logos
# FRONTEND_DIR=/var/lib/recordServer/public
# ALLOWED_ORIGIN=http://localhost:5173
